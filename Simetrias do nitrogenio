def camera_para_plano_sigma(phi, distancia=7.0, altura=3.6, deslocamento_lateral=0.65):
    """
    Retorna uma posição de câmera quase de frente para um plano sigma_v.

    O plano sigma_v contém:
        - o eixo z;
        - a direção radial de ângulo phi.

    A câmera fica aproximadamente na direção normal ao plano,
    com um pequeno deslocamento lateral para manter profundidade visual.
    """

    normal = Vector((-math.sin(phi), math.cos(phi), 0)).normalized()
    direcao_plano = Vector((math.cos(phi), math.sin(phi), 0)).normalized()

    pos = distancia * normal + deslocamento_lateral * direcao_plano + Vector((0, 0, altura))

    return pos


