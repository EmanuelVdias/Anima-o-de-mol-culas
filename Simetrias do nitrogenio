def key_rig(frame):
    key_transform(reflexao_outer, frame, loc=False, rot=True, scale=False)
    key_transform(reflexao_scale, frame, loc=False, rot=False, scale=True)
    key_transform(molecula_empty, frame, loc=False, rot=True, scale=False)


def estado_identidade(frame):
    reflexao_outer.rotation_euler = (0, 0, 0)
    reflexao_scale.scale = (1, 1, 1)
    molecula_empty.rotation_euler = (0, 0, 0)
    key_rig(frame)


def estado_rotacao_c3(theta, frame):
    reflexao_outer.rotation_euler = (0, 0, 0)
    reflexao_scale.scale = (1, 1, 1)
    molecula_empty.rotation_euler = (0, 0, theta)
    key_rig(frame)


def estado_reflexao(phi, s, frame):
    # Transformação total:
    # R(phi) * escala_y(s) * R(-phi)
    #
    # Quando s = 1, a molécula fica igual.
    # Quando s = -1, temos a reflexão no plano vertical de ângulo phi.

    reflexao_outer.rotation_euler = (0, 0, phi)
    reflexao_scale.scale = (1, s, 1)
    molecula_empty.rotation_euler = (0, 0, -phi)
    key_rig(frame)


def animar_rotacao(theta_ini, theta_fim, frame_ini, frame_fim, passos=36):
    for i in range(passos + 1):
        t = i / passos
        frame = int(frame_ini + t * (frame_fim - frame_ini))
        theta = theta_ini + t * (theta_fim - theta_ini)
        estado_rotacao_c3(theta, frame)


def animar_reflexao(phi, frame_ini, frame_fim, passos=24):
    for i in range(passos + 1):
        t = i / passos
        frame = int(frame_ini + t * (frame_fim - frame_ini))

        # s vai de 1 até -1
        s = 1 - 2 * t
        estado_reflexao(phi, s, frame)

