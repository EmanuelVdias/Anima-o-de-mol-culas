# ============================================================
# FUNÇÃO DO MODO NORMAL: ESTIRAMENTO SIMÉTRICO
# ============================================================

def aplicar_estiramento_simetrico(q, frame):
    """
    q > 0:
        os três hidrogênios se afastam do nitrogênio.

    q < 0:
        os três hidrogênios se aproximam do nitrogênio.

    O nitrogênio se move pouco ao longo do eixo C3,
    no sentido oposto ao movimento coletivo dos H.
    """

    massa_H = 1.0
    massa_N = 14.0

    # Para algo mais físico, use 1.0.
    # Para apresentação, 2.0 deixa o movimento do N visível.
    exagero_nitrogenio = 2.0

    deslocamentos_H = [
        q * u[i]
        for i in range(3)
    ]

    soma_deslocamentos_H = deslocamentos_H[0] + deslocamentos_H[1] + deslocamentos_H[2]

    # Mantém o centro de massa aproximadamente fixo:
    # mN*dN + mH*(dH1+dH2+dH3) = 0
    dN = -exagero_nitrogenio * (massa_H / massa_N) * soma_deslocamentos_H

    N_pos = N_eq + dN

    H_pos = [
        H_eq[i] + deslocamentos_H[i]
        for i in range(3)
    ]

    nitrogenio.location = N_pos

    for i in range(3):
        hidrogenios[i].location = H_pos[i]
        posicionar_cilindro_entre_pontos(ligacoes[i], N_pos, H_pos[i])

    key_esfera(nitrogenio, frame)

    for i in range(3):
        key_esfera(hidrogenios[i], frame)
        key_cilindro(ligacoes[i], frame)

# ============================================================
# ANIMAÇÃO
# ============================================================

# Pausa inicial
aplicar_estiramento_simetrico(0.0, 1)
aplicar_estiramento_simetrico(0.0, 45)

# Vibração
amplitude = 0.38

frame_inicio = 50
frame_fim = 500

numero_de_ciclos = 5
passos = 150

for i in range(passos + 1):
    t = i / passos
    frame = int(frame_inicio + t * (frame_fim - frame_inicio))

    fase = 2 * math.pi * numero_de_ciclos * t
    q = amplitude * math.sin(fase)

    aplicar_estiramento_simetrico(q, frame)

# Volta ao equilíbrio
aplicar_estiramento_simetrico(0.0, 510)
aplicar_estiramento_simetrico(0.0, 520)

