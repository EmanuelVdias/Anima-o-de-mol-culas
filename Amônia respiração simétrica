# ============================================================
# MATERIAIS
# ============================================================

def criar_material(nome, cor, alpha=1.0, transparente=False):
    mat = bpy.data.materials.new(nome)
    mat.diffuse_color = cor

    mat.use_nodes = True
    bsdf = mat.node_tree.nodes.get("Principled BSDF")

    if bsdf:
        if "Base Color" in bsdf.inputs:
            bsdf.inputs["Base Color"].default_value = cor
        if "Alpha" in bsdf.inputs:
            bsdf.inputs["Alpha"].default_value = alpha
        if "Roughness" in bsdf.inputs:
            bsdf.inputs["Roughness"].default_value = 0.45

    if transparente:
        mat.blend_method = 'BLEND'
        mat.show_transparent_back = True

    return mat


mat_nitrogenio = criar_material("Nitrogênio azul", (0.05, 0.25, 1.0, 1.0))
mat_hidrogenio = criar_material("Hidrogênio verde", (0.0, 0.85, 0.1, 1.0))
mat_ligacao = criar_material("Ligação cinza", (0.65, 0.65, 0.65, 1.0))

mat_referencia = criar_material(
    "Referência transparente",
    (0.9, 0.9, 0.9, 0.18),
    alpha=0.18,
    transparente=True
)

mat_seta = criar_material("Setas amarelas", (1.0, 0.82, 0.05, 1.0))

# ============================================================
# FUNÇÕES AUXILIARES
# ============================================================

def criar_esfera(nome, posicao, raio, material):
    bpy.ops.mesh.primitive_uv_sphere_add(
        segments=64,
        ring_count=32,
        radius=raio,
        location=posicao
    )
    obj = bpy.context.object
    obj.name = nome
    obj.data.materials.append(material)
    bpy.ops.object.shade_smooth()
    return obj


def criar_cilindro_unitario(nome, raio, material):
    bpy.ops.mesh.primitive_cylinder_add(
        vertices=48,
        radius=raio,
        depth=1.0,
        location=(0, 0, 0)
    )

    obj = bpy.context.object
    obj.name = nome
    obj.rotation_mode = 'QUATERNION'
    obj.data.materials.append(material)
    bpy.ops.object.shade_smooth()
    return obj


def posicionar_cilindro_entre_pontos(obj, p1, p2):
    p1 = Vector(p1)
    p2 = Vector(p2)

    meio = (p1 + p2) / 2
    direcao = p2 - p1
    comprimento = direcao.length

    obj.location = meio

    if comprimento > 0:
        obj.rotation_quaternion = direcao.to_track_quat('Z', 'Y')

    obj.scale = (1, 1, comprimento)


def criar_cilindro_entre_pontos(nome, p1, p2, raio, material):
    obj = criar_cilindro_unitario(nome, raio, material)
    posicionar_cilindro_entre_pontos(obj, p1, p2)
    return obj


def criar_cone_alinhado(nome, ponta, direcao, raio, profundidade, material):
    direcao = Vector(direcao).normalized()
    ponta = Vector(ponta)

    centro = ponta - direcao * (profundidade / 2)

    bpy.ops.mesh.primitive_cone_add(
        vertices=48,
        radius1=raio,
        radius2=0,
        depth=profundidade,
        location=centro
    )

    obj = bpy.context.object
    obj.name = nome
    obj.rotation_euler = direcao.to_track_quat('Z', 'Y').to_euler()
    obj.data.materials.append(material)
    bpy.ops.object.shade_smooth()
    return obj


def criar_seta(nome, inicio, fim, raio, material):
    inicio = Vector(inicio)
    fim = Vector(fim)
    direcao = fim - inicio

    if direcao.length == 0:
        return []

    direcao = direcao.normalized()

    profundidade_cone = 0.35
    raio_cone = 0.16

    fim_cilindro = fim - direcao * profundidade_cone

    haste = criar_cilindro_entre_pontos(
        nome + " haste",
        inicio,
        fim_cilindro,
        raio,
        material
    )

    cone = criar_cone_alinhado(
        nome + " ponta",
        fim,
        direcao,
        raio_cone,
        profundidade_cone,
        material
    )

    return [haste, cone]


def olhar_para(obj, alvo):
    direcao = Vector(alvo) - obj.location
    obj.rotation_euler = direcao.to_track_quat('-Z', 'Y').to_euler()


def key_visibilidade(obj, visivel, frame):
    obj.hide_viewport = not visivel
    obj.hide_render = not visivel
    obj.keyframe_insert(data_path="hide_viewport", frame=frame)
    obj.keyframe_insert(data_path="hide_render", frame=frame)


def key_visibilidade_lista(lista, visivel, frame):
    for obj in lista:
        key_visibilidade(obj, visivel, frame)


def key_esfera(obj, frame):
    obj.keyframe_insert(data_path="location", frame=frame)


def key_cilindro(obj, frame):
    obj.keyframe_insert(data_path="location", frame=frame)
    obj.keyframe_insert(data_path="rotation_quaternion", frame=frame)
    obj.keyframe_insert(data_path="scale", frame=frame)

# ============================================================
# GEOMETRIA DA AMÔNIA
# ============================================================

# Convenção:
# eixo z = eixo C3
# N fica acima
# os três H formam uma base triangular abaixo

N_eq = Vector((0, 0, 0.75))

raio_H = 1.55
z_H = -0.45

phis_H = [
    math.radians(90),
    math.radians(210),
    math.radians(330)
]

H_eq = [
    Vector((raio_H * math.cos(phi), raio_H * math.sin(phi), z_H))
    for phi in phis_H
]

# Direções das ligações N -> H
u = [
    (H_eq[i] - N_eq).normalized()
    for i in range(3)
]

# ============================================================
# MOLÉCULA PRINCIPAL
# ============================================================

nitrogenio = criar_esfera("Nitrogênio", N_eq, 0.52, mat_nitrogenio)

hidrogenios = [
    criar_esfera(f"Hidrogênio {i+1}", H_eq[i], 0.34, mat_hidrogenio)
    for i in range(3)
]

ligacoes = [
    criar_cilindro_entre_pontos(
        f"Ligação N-H {i+1}",
        N_eq,
        H_eq[i],
        0.11,
        mat_ligacao
    )
    for i in range(3)
]

# ============================================================
# MOLÉCULA DE REFERÊNCIA TRANSPARENTE
# ============================================================

N_ref = criar_esfera("Nitrogênio referência", N_eq, 0.53, mat_referencia)

H_ref = [
    criar_esfera(f"Hidrogênio referência {i+1}", H_eq[i], 0.35, mat_referencia)
    for i in range(3)
]

L_ref = [
    criar_cilindro_entre_pontos(
        f"Ligação referência {i+1}",
        N_eq,
        H_eq[i],
        0.055,
        mat_referencia
    )
    for i in range(3)
]

objetos_referencia = [N_ref] + H_ref + L_ref

# ============================================================
# SETAS DO ESTIRAMENTO SIMÉTRICO
# ============================================================

# Para q > 0:
# os três H se afastam do N ao longo das ligações;
# o N sobe um pouco no eixo C3.

objetos_setas = []

for i in range(3):
    objetos_setas += criar_seta(
        f"Seta H{i+1}",
        H_eq[i] + 0.10 * u[i],
        H_eq[i] + 0.80 * u[i],
        0.045,
        mat_seta
    )

# seta pequena do nitrogênio
objetos_setas += criar_seta(
    "Seta N",
    N_eq + Vector((0, 0, 0.10)),
    N_eq + Vector((0, 0, 0.62)),
    0.035,
    mat_seta
)

